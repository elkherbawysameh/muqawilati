# انسخ هذا الملف وسمّه .env وعبّئ القيم

# ─── Supabase PostgreSQL ───────────────────────────────────────────────────────
# احصل على هذا الرابط من: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── JWT Secret ────────────────────────────────────────────────────────────────
# اكتب أي نص طويل عشوائي هنا (لا تشاركه مع أحد)
JWT_SECRET=change_this_to_a_long_random_secret_string_2024

# ─── App Settings ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
